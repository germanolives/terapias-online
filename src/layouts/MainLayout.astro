---
// MainLayout.astro
import "../styles/global.css";
import SpeedInsights from "@vercel/speed-insights/astro"
import BaseHead from "../components/BaseHead.astro";
import Navbar from "../components/Navbar.astro";
import Modal from "../components/Modal.astro";
import FloatingActions from "../components/FloatingActions.astro";
import Footer from "../components/Footer.astro";
import { isSpainHost } from "../lib/domain";

interface Props {
  title: string;
  description?: string; // Agregamos una descripción opcional
}

const isSpain = isSpainHost(Astro.url.hostname);
const {
  title,
  description = isSpain
    ? "Lic. Graciela Aballay - Psicóloga General Sanitaria. Psicoterapia online para residentes en España."
    : "Lic. Graciela Aballay - Psicóloga UBA. Especialista en Terapia Cognitivo Conductual y Psicoanálisis en Buenos Aires. Consultas online y presenciales.",
} = Astro.props;
---

<html lang="es">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="bg-clinica-soft text-gray-800" data-country={isSpain ? "es" : "ar"}>
    <Navbar isSpain={isSpain} />
    <main><slot /></main>
    <Footer isSpain={isSpain} />
    <FloatingActions isSpain={isSpain} />
    <Modal />
    <SpeedInsights />
  </body>
</html>
