---
// Navbar.astro
interface Props {
  isSpain?: boolean;
}

const { isSpain = false } = Astro.props;
---
<nav class="bg-white border-b border-gray-100 sticky top-0 z-50 shadow-sm">
  <div class="max-w-4xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-clinica-primary">
      {isSpain ? "Psicoterapia" : "Terapias"} <span class="text-clinica-accent">Online</span>
    </a>

    <div class="hidden md:flex items-center space-x-6 text-sm font-medium text-gray-600">
      <a href="/" class="hover:text-clinica-primary transition-colors">Inicio</a>
      <a href="#about-me" class="hover:text-clinica-primary transition-colors">Sobre mí</a>
      <a href="#services" class="hover:text-clinica-primary transition-colors">Servicios</a>
      <a href="#contact" class="bg-clinica-primary text-white px-4 py-2 rounded-lg hover:bg-clinica-accent transition-colors">
        Contacto
      </a>
    </div>

    <button id="menu-btn" class="md:hidden p-2 text-gray-600 focus:outline-none" aria-label="Abrir menú">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 px-4 py-4 space-y-4 shadow-inner">
    <a href="/" class="block text-gray-600 hover:text-clinica-primary font-medium border-b border-gray-50 pb-2">Inicio</a>
    <a href="#about-me" class="block text-gray-600 hover:text-clinica-primary font-medium border-b border-gray-50 pb-2">Sobre mí</a>
    <a href="#services" class="block text-gray-600 hover:text-clinica-primary font-medium border-b border-gray-50 pb-2">Servicios</a>
    <a href="#contact" class="block bg-clinica-primary text-white px-4 py-2 rounded-lg text-center font-bold">Contacto</a>
  </div>
</nav>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const links = menu?.querySelectorAll('a'); // Buscamos todos los links dentro del menú móvil

  // Abrir/Cerrar al tocar el botón
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // CERRAR automáticamente al tocar cualquier link
  links?.forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });
</script>