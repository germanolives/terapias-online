---
// src/components/Hero.astro
import { Image } from "astro:assets";
import fotoGraciela from "../assets/graciela-hero.webp";
import { isSpainHost } from "../lib/domain";

const isSpain = isSpainHost(Astro.url.hostname);
const primaryCta = isSpain ? "Solicitar Cita" : "Solicitar Turno";
const secondaryCta = isSpain ? "Conóceme más" : "Conoceme más";
---

<section class="relative bg-clinica-soft py-16 md:py-24 overflow-hidden w-full">
  <div
    class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-12"
  >
    <div class="flex-1">
      <h1
        class="text-4xl md:text-6xl font-extrabold text-clinica-primary tracking-tight leading-tight"
      >
        Lic. <span class="text-clinica-accent">Graciela Verónica Aballay</span>
      </h1>
      {
        isSpain ? (
          <div class="mt-6 text-gray-700 leading-snug">
            <p class="text-4xl font-semibold">Psicóloga General Sanitaria</p>
            <p class="text-lg font-medium mt-1">Universidad de Buenos Aires - M.N. 70449</p>
            <p class="text-base mt-1">(Título UBA homologado en España)</p>
          </div>
        ) : (
        <div class="mt-6 text-gray-700 leading-snug">
            <p class="text-4xl font-semibold">Psicóloga</p>
            <p class="text-lg font-medium mt-1">Universidad de Buenos Aires - M.N. 70449</p>
          </div>
        )
      }
      <p class="mt-6 text-lg text-gray-600 max-w-xl leading-relaxed">
        Especialista en Terapia Cognitivo Conductual y Psicoanálisis.
        Acompañamiento profesional para transitar procesos de cambio y bienestar
        emocional.
      </p>
      <div
        class="mt-10 flex flex-col sm:flex-row gap-4 justify-center md:justify-start"
      >
        <a
          href="#contact"
          class="bg-clinica-primary text-white px-8 py-4 rounded-full font-bold text-lg hover:scale-105 transition-transform shadow-xl inline-block text-center"
        >
          {primaryCta}
        </a>
        <a
          href="#about-me"
          class="border-2 border-clinica-primary text-clinica-primary px-8 py-4 rounded-full font-bold text-lg hover:bg-clinica-primary hover:text-white transition-all inline-block text-center"
        >
          {secondaryCta}
        </a>
      </div>
    </div>

    <div class="flex-1 relative">
      <div
        class="absolute inset-0 bg-clinica-primary/10 rounded-full blur-3xl transform scale-110"
      >
      </div>

      <div
        class="relative w-72 h-72 md:w-96 md:h-96 mx-auto rotate-2 hover:rotate-0 transition-transform duration-500"
      >
        <div
          class="absolute inset-0 rounded-2xl bg-gray-300 animate-pulse"
          data-skeleton
        >
        </div>

        <Image
          src={fotoGraciela}
          alt="Lic. Graciela Aballay"
          width={400}
          height={400}
          loading="eager"
          onload="this.classList.remove('opacity-0'); this.classList.add('opacity-100'); this.parentElement.querySelector('[data-skeleton]')?.classList.add('hidden')"
          class="w-full h-full object-cover rounded-2xl shadow-2xl border-4 border-white opacity-0 transition-opacity duration-500"
        />
      </div>
    </div>
  </div>
</section>
