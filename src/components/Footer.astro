---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-white border-t border-gray-100 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <div class="flex flex-col">
        <h2 class="text-2xl font-bold text-clinica-primary leading-tight">
          Graciela Aballay
        </h2>
        <p class="text-gray-800 text-sm font-medium mb-4">
          Licenciada en Psicología (UBA)
        </p>

        <div class="space-y-4">
          <p class="text-gray-500 text-sm leading-relaxed">
            Psicóloga clínica especializada en acompañamiento terapéutico y
            autonomía en el desarrollo.
          </p>
          <div
            class="inline-block bg-clinica-soft px-3 py-1 rounded-full border border-clinica-accent/20"
          >
            <span class="text-xs font-semibold text-clinica-primary"
              >Matrícula Nacional: 70.449</span
            >
          </div>
        </div>
      </div>

      <div>
        <h3
          class="text-sm font-bold uppercase tracking-wider text-gray-900 mb-6"
        >
          Navegación
        </h3>
        <ul class="space-y-4">
          <li>
            <a
              href="/"
              class="group flex items-center text-gray-500 hover:text-clinica-primary transition-all duration-300"
            >
              <span
                class="transform group-hover:translate-x-2 transition-transform duration-300"
                >Inicio</span
              >
            </a>
          </li>
          <li>
            <a
              href="#services"
              class="group flex items-center text-gray-500 hover:text-clinica-primary transition-all duration-300"
            >
              <span
                class="transform group-hover:translate-x-2 transition-transform duration-300"
                >Servicios</span
              >
            </a>
          </li>
          <li>
            <a
              href="#about-me"
              class="group flex items-center text-gray-500 hover:text-clinica-primary transition-all duration-300"
            >
              <span
                class="transform group-hover:translate-x-2 transition-transform duration-300"
                >Sobre Mí</span
              >
            </a>
          </li>
          <li>
            <a
              href="#contact"
              class="group flex items-center text-gray-500 hover:text-clinica-primary transition-all duration-300"
            >
              <span
                class="transform group-hover:translate-x-2 transition-transform duration-300"
                >Contacto</span
              >
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3
          class="text-sm font-bold uppercase tracking-wider text-gray-900 mb-6"
        >
          Contacto Directo
        </h3>
        <ul class="space-y-4 text-gray-500">
          <li class="flex items-center gap-3 italic">
            📍 Buenos Aires, Argentina
          </li>
          <li class="flex items-center gap-3 italic">
            <span>✉️</span>
            <a
              href="mailto:licenciadaaballay@gmail.com?subject=Consulta%20desde%20la%20Web"
            >
              licenciadaaballay@gmail.com
            </a>
          </li>
          <li class="flex items-center gap-3 italic">
            🕒 Lunes a Viernes - Horarios a convenir
          </li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-gray-100">
      <div class="max-w-2xl mx-auto text-center space-y-2">
        <p class="text-gray-400 text-sm">
          &copy; {currentYear} Lic. Graciela Aballay. Todos los derechos reservados.
        </p>
        <p class="text-gray-400 text-[10px] leading-relaxed px-8">
          Desarrollado con ❤️ para la salud mental por:<br class="md:hidden" />
          <a
            href="mailto:siempreytodoslosdias@gmail.com?subject=Consulta%20Web%20Graciela%20Aballay"
            class="hover:text-clinica-primary transition-colors underline decoration-gray-400/30 underline-offset-4"
          >
            siempreytodoslosdias@gmail.com
          </a>
        </p>
      </div>
    </div>
  </div>
</footer>
