---
// Definimos qué datos necesita recibir esta tarjeta
interface Props {
  title: string;
  description: string;
  icon: string; // Aquí pasaremos el nombre de un icono o un emoji por ahora
}

const { title, description, icon } = Astro.props;
---

<div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow group">
  <div class="w-12 h-12 bg-clinica-soft rounded-lg flex items-center justify-center text-2xl mb-6 group-hover:bg-clinica-primary group-hover:text-white transition-colors">
    {icon}
  </div>
  
  <h3 class="text-xl font-bold text-gray-800 mb-3 group-hover:text-clinica-primary transition-colors">
    {title}
  </h3>
  
  <p class="text-gray-600 leading-relaxed">
    {description}
  </p>
</div>