---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/Hero.astro"; // Importamos el nuevo Hero
import Services from "../components/Services.astro";
import AboutMe from "../components/AboutMe.astro";
import Contact from "../components/Contact.astro";
import TrustShield from "../components/TrustShield.astro";
import { getPsychologySchemas } from "../lib/seo-logic";
import { isSpainHost } from "../lib/domain";

const schemas = getPsychologySchemas(Astro.url.hostname);
const isSpain = isSpainHost(Astro.url.hostname);
const pageTitle = isSpain
  ? "Lic. Graciela Aballay | Psicoterapia Online en España"
  : "Lic. Graciela Aballay | Terapias Online en Argentina";
---

<MainLayout title={pageTitle}>
  <Hero />
  <Services />
  <AboutMe />
  <TrustShield />
  <Contact />
</MainLayout>

{
  schemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
