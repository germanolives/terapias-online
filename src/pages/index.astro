---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/Hero.astro"; // Importamos el nuevo Hero
import Services from "../components/Services.astro";
import AboutMe from "../components/AboutMe.astro";
import Contact from "../components/Contact.astro";
import { getDomainConfig, isSpainHost } from "../lib/domain";

const domainConfig = getDomainConfig(Astro.url.hostname);
const isSpain = isSpainHost(Astro.url.hostname);
const businessSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  name: "Lic. Graciela Verónica Aballay",
  image: `${domainConfig.canonicalOrigin}/assets/graciela-hero.webp`,
  url: domainConfig.canonicalOrigin,
  description:
    "Psicóloga clínica graduada en la UBA, especialista en TCC y Psicoanálisis.",
  address: {
    "@type": "PostalAddress",
    addressLocality: isSpain ? "España" : "Buenos Aires",
    addressCountry: isSpain ? "ES" : "AR",
  },
  medicalSpecialty: "Psychotherapy",
  telephone: domainConfig.whatsappDisplay,
};
---

<MainLayout title="Lic. Graciela Aballay | Psicóloga Online">
  <Hero />
  <Services />
  <AboutMe />
  <Contact />
</MainLayout>

<script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
