---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/Hero.astro"; // Importamos el nuevo Hero
import Services from "../components/Services.astro";
import AboutMe from "../components/AboutMe.astro";
import Contact from "../components/Contact.astro";
import TrustShield from "../components/TrustShield.astro";
import { getPsychologySchemas } from "../lib/seo-logic";

const schemas = getPsychologySchemas(Astro.url.hostname);
---

<MainLayout title="Lic. Graciela Aballay | Psicóloga Online">
  <Hero />
  <Services />
  <AboutMe />
  <TrustShield />
  <Contact />
</MainLayout>

{
  schemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
